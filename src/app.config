<?xml version="1.0" encoding="utf-8"?>
<configuration>
  
  <!-- 支援的執行階段版本 -->
  <startup>
    <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.0" />
  </startup>

  <!-- 網路設定 -->
  <system.net>
    <!-- 允許不安全的標頭解析（相容某些網站回應） -->
    <settings>
      <httpWebRequest useUnsafeHeaderParsing="true" />
    </settings>
    <!-- 增加預設連線數 -->
    <connectionManagement>
      <add address="*" maxconnection="20" />
    </connectionManagement>
  </system.net>

  <!-- 應用程式設定 -->
  <appSettings>
    <!-- 使用者代理字串 -->
    <add key="UserAgent" value="Mozilla/5.0 (Windows NT 6.1; WOW64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/92.0.4515.131 Safari/537.36" />
    <!-- HTTP 請求逾時（毫秒） -->
    <add key="HttpTimeout" value="15000" />
    <!-- 搜尋結果最大數量 -->
    <add key="MaxSearchResults" value="20" />
    <!-- 編譯輸出目錄 -->
    <add key="CompileOutputDir" value="GeneratedCode" />
  </appSettings>

</configuration>
